{
  "name": "blooms-energy-raw-powders",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cd vedantu && npm run dev",
    "build": "cd vedantu && npm install && npm run build",
    "start": "cd vedantu && npm start",
    "lint": "cd vedantu && npm run lint",
    "seed": "cd vedantu && npx tsx src/scripts/seed.ts",
    "import": "cd vedantu && npx tsx src/scripts/import-data.ts",
    "emulator": "cd vedantu && firebase emulators:start",
    "seed:emulator": "cd vedantu && firebase emulators:start --only firestore & sleep 5 && npx tsx src/scripts/import-data.ts && firebase emulators:stop",
    "import:emulator": "cd vedantu && firebase emulators:start --only firestore & sleep 5 && npx tsx src/scripts/import-data.ts && firebase emulators:stop"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "firebase": "^12.8.0",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.344.0",
    "next": "^14.1.0",
    "razorpay": "^2.9.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
}
