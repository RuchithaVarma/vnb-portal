{
  "name": "learner",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "npx tsx src/scripts/seed.ts",
    "import": "npx tsx src/scripts/import-data.ts",
    "emulator": "firebase emulators:start",
