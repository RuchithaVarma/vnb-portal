    "import:emulator": "firebase emulators:start --only firestore & sleep 5 && npx tsx src/scripts/import-data.ts && firebase emulators:stop",
    "import:simple": "npx tsx src/scripts/import-data.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
